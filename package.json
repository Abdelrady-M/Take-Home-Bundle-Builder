{
  "name": "wyze-bundle-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf ./node_modules/.vite && unlink yarn.lock && yarn update && yarn install && yarn start",
    "update": "npx ncu -u",
    "fix": "npx eslint --fix ./src",
    "lint": "yarn fix --max-warnings 0",
    "format": "npx prettier --write ./src --config ./.prettierrc.json",
    "start": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "npx huskier-init && husky install",
    "postinstall": "agent-kit sync",
    "tsc": "npx tsc --noEmit"
  },
  "dependencies": {
    "@mongez/cache": "^1.3.4",
    "@mongez/config": "^1.1.4",
    "@mongez/dom": "^1.2.4",
    "@mongez/events": "^2.2.6",
    "@mongez/http": "^3.3.8",
    "@mongez/huskier": "^3.0.0",
    "@mongez/localization": "^3.4.6",
    "@mongez/react": "^3.2.2",
    "@mongez/react-atom": "^6.0.9",
    "@mongez/react-form": "^3.4.8",
    "@mongez/react-helmet": "^1.2.3",
    "@mongez/react-hooks": "^1.3.3",
    "@mongez/react-localization": "^3.4.6",
    "@mongez/react-router": "^2.7.4",
    "@mongez/reinforcements": "^3.3.0",
    "@mongez/supportive-is": "^2.1.3",
    "@mongez/user": "^1.1.6",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-window": "^2.2.7",
    "sass": "^1.101.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@mongez/agent-kit": "^1.2.0",
    "@mongez/vite": "^2.1.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^8.0.0",
    "npm-check-updates": "^22.2.9",
    "postcss": "^8.5.16",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-svgr": "^5.2.0"
  },
  "huskier": {
    "hooks": {
      "pre-commit": [
        "yarn format",
        "yarn lint",
        "yarn tsc"
      ]
    }
  },
  "agentKit": {
    "targets": [
      "claude"
    ]
  }
}

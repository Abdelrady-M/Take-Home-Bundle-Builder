# Shared environment variables for all environments
# App Name
APP_NAME="Wyze Bundle Builder"

# Favicon
APP_ICON=/vite.svg

# App Code Name
APP_CODE_NAME="wyze-bundle-builder"

# App Description
APP_DESCRIPTION="Configure a Wyze home security bundle and review it live."

# App default locale code
APP_DEFAULT_LOCALE_CODE=en

# App Fallback locale code
APP_FALLBACK_LOCALE_CODE=en

# Project Version
APP_VERSION=1.0.0

# App default direction
APP_DEFAULT_DIRECTION=ltr